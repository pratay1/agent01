<Window x:Class="PhysicsSandbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhysicsSandbox"
        Title="Physics Sandbox" Height="800" Width="1300"
        Background="#0A0A0A" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid>
        <!-- Main canvas spans entire grid, behind all floating elements -->
        <local:PhysicsCanvas x:Name="GameCanvas" Grid.RowSpan="3" ClipToBounds="True" Background="#0A0A0A"/>

        <!-- Floating top bar: title left, controls right -->
        <Border Grid.Row="0" Background="Transparent" Padding="24,16">
            <DockPanel>
                <!-- Title -->
                <TextBlock Text="PHYSICS SANDBOX" Foreground="#FFFFFF" FontSize="28"
                           FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>

                <!-- Spacer -->
                <Border Width="40"/>

                <!-- Right panel: active body, status, buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Right">
                    <!-- Active body chip -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="10,6" Margin="0,0,12,0"
                            BorderBrush="#2A2A2A" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="SelectedBodyColor" Width="14" Height="14" StrokeThickness="0"/>
                            <TextBlock x:Name="SelectedBodyName" Text="Normal" Foreground="#FFFFFF"
                                       FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Width="1" Background="#2A2A2A" VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusText" Text="0 bodies" Foreground="#888888"
                               FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>

                    <!-- Spacer -->
                    <Border Width="12"/>

                    <!-- Buttons group -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ClearButton" Content="CLEAR" Click="ClearButton_Click"
                                Width="64" Height="32" Background="#1A1A1A" Foreground="#FFFFFF"
                                BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                Margin="0,0,8,0"/>
                        <Button x:Name="PauseButton" Content="PAUSE" Click="PauseButton_Click"
                                Width="72" Height="32" Background="#1A1A1A" Foreground="#FFFFFF"
                                BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                                FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Floating right sidebar: body type selector -->
        <Border HorizontalAlignment="Right" Width="200"
                Background="#121212" BorderBrush="#1A1A1A" BorderThickness="1,0,0,0"
                Padding="20,60,20,24" VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="0">
                <StackPanel>
                    <TextBlock Text="BODY TYPES" Foreground="#555555" FontSize="9"
                               FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,16"/>

                    <!-- Body type buttons -->
                    <Button x:Name="BtnNormal" Click="BodyTypeButton_Click" Tag="Normal"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnBouncy" Click="BodyTypeButton_Click" Tag="Bouncy"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnHeavy" Click="BodyTypeButton_Click" Tag="Heavy"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnExplosive" Click="BodyTypeButton_Click" Tag="Explosive"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnRepulsor" Click="BodyTypeButton_Click" Tag="Repulsor"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnGravityWell" Click="BodyTypeButton_Click" Tag="GravityWell"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnTurbo" Click="BodyTypeButton_Click" Tag="Turbo"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnPhantom" Click="BodyTypeButton_Click" Tag="Phantom"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnSpike" Click="BodyTypeButton_Click" Tag="Spike"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnGlue" Click="BodyTypeButton_Click" Tag="Glue"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnPlasma" Click="BodyTypeButton_Click" Tag="Plasma"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnBlackHole" Click="BodyTypeButton_Click" Tag="BlackHole"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnLightning" Click="BodyTypeButton_Click" Tag="Lightning"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnFire" Click="BodyTypeButton_Click" Tag="Fire"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnAngel" Click="BodyTypeButton_Click" Tag="Angel"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                    <Button x:Name="BtnMolly" Click="BodyTypeButton_Click" Tag="Molly"
                            Height="36" Padding="12,0" Background="#1A1A1A" Foreground="#AAAAAA"
                            BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand"
                            FontSize="11" FontFamily="Consolas" HorizontalContentAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom left: help text & controls legend -->
        <Border Grid.Row="2" Background="Transparent" Padding="24,12" HorizontalAlignment="Left">
            <TextBlock Foreground="#333333" FontSize="10" FontFamily="Consolas"
                       Text="LMB: SPAWN | RMB: EXPLODE | SPACE: PAUSE | C: CLEAR | G: GRAVITY | W: WIND | +/- : SPEED"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</Window>
