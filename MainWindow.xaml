<Window x:Class="PhysicsSandbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhysicsSandbox"
        Title="Physics Agent" Height="935" Width="1400"
        Background="#0D0D0D" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        FontFamily="Consolas">
    <Window.Resources>
        <!-- Title Screen Button Style -->
        <Style x:Key="TitleScreenButton" TargetType="Button">
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="BorderBrush" Value="#4FC3F7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="BorderBrush" Value="#252525"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button Styles -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Selected Body Chip Style -->
        <Style x:Key="SelectedBodyChip" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        
        <!-- TextBlock Styles -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        
        <Style x:Key="SidebarHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>
    
    <Grid x:Name="MainGrid">
        <!-- Title Screen Overlay - shown before game starts -->
        <Border x:Name="TitleScreen" Visibility="Visible" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#0A0A0F" Offset="0"/>
                    <GradientStop Color="#0F0F18" Offset="0.5"/>
                    <GradientStop Color="#0A0A14" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- Subtle animated grid pattern overlay -->
            <Border.OpacityMask>
                <VisualBrush Stretch="None" TileMode="Tile" Viewport="0,0,60,60" ViewportUnits="Absolute">
                    <VisualBrush.Visual>
                        <Path Data="M0,30 L60,30 M30,0 L30,60" Stroke="#1A1A28" StrokeThickness="0.5"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Floating geometric accent shapes -->
                <Canvas Grid.RowSpan="7" IsHitTestVisible="False">
                    <Ellipse Canvas.Left="120" Canvas.Top="120" Width="400" Height="400" Fill="#1A1A28" Opacity="0.45"/>
                    <Ellipse Canvas.Left="-80" Canvas.Top="280" Width="220" Height="220" Fill="#16213E" Opacity="0.25"/>
                    <Path Data="M1220,140 L1320,260 L1100,260 Z" Fill="#0F3460" Opacity="0.15"/>
                    <Ellipse Canvas.Left="1140" Canvas.Top="360" Width="180" Height="180" Fill="#16213E" Opacity="0.2"/>
                </Canvas>

                <!-- Top decorative line -->
                <Border Grid.Row="1" Height="2" Background="#4D4D7A" HorizontalAlignment="Center" Width="80" Margin="0,0,0,40" Opacity="0.5"/>

                <!-- Main Title -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                    <TextBlock Text="PHYSICS" 
                               FontSize="48" 
                               FontWeight="Bold" 
                               Foreground="#E8E8F0" 
                               FontFamily="Segoe UI, Consolas"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#4D4D7A" Direction="315" ShadowDepth="4" BlurRadius="16" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="SANDBOX" 
                               FontSize="48" 
                               FontWeight="Bold" 
                               Foreground="#8B5CF6" 
                               FontFamily="Segoe UI, Consolas"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8B5CF6" Direction="315" ShadowDepth="4" BlurRadius="16" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- Subtitle -->
                <TextBlock Grid.Row="3" Text="Interactive 2D Physics Simulation" 
                           FontSize="14" 
                           Foreground="#9CA3AF" 
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,50"/>

                <!-- Menu Buttons Container -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" Width="360">
                    <!-- Primary Button: 2D Physics Sandbox -->
<Button x:Name="Start2DButton" 
                             Click="Start2DPhysics_Click"
                             Style="{StaticResource TitleScreenButton}" 
                             Margin="0,0,0,16"
                             Height="60"
                             Width="360">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A78BFA" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.BorderBrush>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" 
                                  Stroke="#FFFFFF" StrokeThickness="2.5" Width="24" Height="24"/>
                            <TextBlock Text="  2D PHYSICS SANDBOX" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                     <!-- Secondary Button: 3D Ragdoll Training (Coming Soon) -->
                     <Button Style="{StaticResource TitleScreenButton}"
                             IsEnabled="False"
                             Height="52"
                             Width="360"
                             Margin="0,0,0,16"
                             Background="#1A1A28"
                             BorderBrush="#2A2A3A">
                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Opacity="0.6">
                             <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                   Stroke="#6B7280" StrokeThickness="1.5" Width="20" Height="20"/>
                             <TextBlock Text="  3D RAGDOLL TRAINING" 
                                        FontSize="13" 
                                        FontWeight="Normal"
                                        VerticalAlignment="Center"
                                        Foreground="#6B7280"/>
                         </StackPanel>
                     </Button>

                     <!-- Quit Button -->
                     <Button x:Name="QuitButton"
                             Click="Quit_Click"
                             Style="{StaticResource TitleScreenButton}"
                             Height="52"
                             Width="360"
                             Margin="0,0,0,16"
                             Background="#1E1E1E"
                             BorderBrush="#2D2D2D">
                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                             <Path Data="M6 18L18 6M6 6l12 12" 
                                   Stroke="#FFFFFF" StrokeThickness="2" Width="12" Height="12"/>
                             <TextBlock Text="  QUIT" 
                                        FontSize="13" 
                                        FontWeight="Normal"
                                        VerticalAlignment="Center"/>
                         </StackPanel>
                     </Button>

                    <!-- Feature badges -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Border Background="#1A1A28" CornerRadius="8" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#10B981" Margin="0,0,5,0"/>
                                <TextBlock Text="17 Body Types" FontSize="9" Foreground="#9CA3AF" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A28" CornerRadius="8" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#3B82F6" Margin="0,0,5,0"/>
                                <TextBlock Text="Real-time Physics" FontSize="9" Foreground="#9CA3AF" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A28" CornerRadius="8" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#F59E0B" Margin="0,0,5,0"/>
                                <TextBlock Text="Chain Reactions" FontSize="9" Foreground="#9CA3AF" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="5" HorizontalAlignment="Center">
                    <TextBlock Text="created by pratay and kilo agent" 
                               FontSize="11" 
                               Foreground="#4B5563" 
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="physics-sandbox v2.0" 
                               FontSize="10" 
                               Foreground="#374151" 
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Corner accent -->
                <Border Grid.RowSpan="7" Width="32" Height="32" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,24,0,0" IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

        <!-- Game UI - Hidden until game starts -->
        <Grid x:Name="GameUI" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Top bar: title and controls -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent" Padding="24,16">
                <DockPanel>
                    <TextBlock Text="PHYSICS SANDBOX" Style="{StaticResource TitleText}"/>
                    <Border Width="40"/>
                    <Grid x:Name="TopRightContainer" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="BodyBarPanel" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource SelectedBodyChip}" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="SelectedBodyColor" Width="16" Height="16" StrokeThickness="0"/>
                                    <TextBlock x:Name="SelectedBodyName" Text="Normal" Style="{StaticResource TitleText}" FontSize="14" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Width="1" Background="#2D2D2D" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="StatusText" Text="0 bodies" Style="{StaticResource StatusText}"/>
                    <TextBlock x:Name="ComboText" Text="Combo: 0" Style="{StaticResource StatusText}" Margin="8,0,0,0"/>
                            <Border Width="16"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SelectedBodyChip}" Margin="0,0,8,0">
                                    <TextBlock x:Name="DescriptionText" Text="Standard physics body" Style="{StaticResource HelpText}" Foreground="#888888" MaxWidth="400" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                            <Border Width="16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ClearButton" Content="CLEAR" Click="ClearButton_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                                <Button x:Name="PauseButton" Content="PAUSE" Click="PauseButton_Click" Style="{StaticResource ActionButton}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="SettingsBarPanel" Orientation="Vertical" Visibility="Collapsed" VerticalAlignment="Center">
            <!-- Night Mode Toggle -->
            <CheckBox x:Name="NightModeCheckBox" Content="Night Mode" IsChecked="False" Checked="NightModeCheckBox_Checked" Unchecked="NightModeCheckBox_Unchecked" Margin="0,4,0,0"/>
            <!-- Grid Size Slider -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="Grid Size:" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                <Slider x:Name="GridSizeSlider" Minimum="10" Maximum="100" Value="20" Width="120" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="GridSizeSlider_ValueChanged" Margin="8,0,0,0"/>
            <!-- Randomizer Button -->
            <Button x:Name="RandomizeButton" Content="Randomize!" Click="RandomizeButton_Click" Style="{StaticResource ActionButton}" Margin="0,8,0,0" Width="100"/>
            </StackPanel>
                            <CheckBox x:Name="WindCheckBox" Content="Enable Wind" IsChecked="False" Checked="WindCheckBox_Checked" Unchecked="WindCheckBox_Unchecked"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Shift Spawn Rate:" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                <Slider x:Name="ShiftSpawnRateSlider" Minimum="1" Maximum="30" Value="14" Width="120" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ShiftSpawnRateSlider_ValueChanged" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Max Shift Spawns:" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                <Slider x:Name="MaxShiftSpawnsSlider" Minimum="1" Maximum="20" Value="10" Width="120" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="MaxShiftSpawnsSlider_ValueChanged" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="TPT:" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TptDisplayText" Text="0.00 ms" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <CheckBox Content="Enable Gravity" IsChecked="True" IsEnabled="False"/>
                            <CheckBox Content="Show Body Names" IsChecked="True" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                    <Button x:Name="SettingsButton" Grid.Column="1" Click="SettingsButton_Click" Width="36" Height="36" Style="{StaticResource ActionButton}" Margin="8,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Path Width="18" Height="18" Fill="#FFFFFF" Data="M12 15.5A3.5 3.5 0 1 0 12 8.5a3.5 3.5 0 0 0 3.5 3.5zm0-5a1.5 1.5 0 1 1-1.5-1.5 1.5 1.5 0 0 1 1.5 1.5zm6.6-2.5l-1.1-2.4a1 1 0 0 0-1.2-.6l-2.9.6a8.02 8.02 0 0 0-1.5-1l.5-3a1 1 0 0 0-1-1.2l-2.4 1.1a8.02 8.02 0 0 0-2-.6l-.6-2.9a1 1 0 0 0-1.2-.6l-2.4 1.1a8.02 8.02 0 0 0-2 .6l-.6 2.9a1 1 0 0 0 1.2 1.2l2.4-1.1a8.02 8.02 0 0 0 2-.6l.6-2.9a1 1 0 0 0-.6-1.2l-2.4-1.1a8.02 8.02 0 0 0 1.5-1l.5-3A1 1 0 0 0 21.1 10.5l2.4 1.1A5 5 0 0 1 20.1 13zm-8.6 3.5a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
                    </Button>
                </DockPanel>
            </Border>
            
            <!-- Left sidebar -->
            <Border Grid.Row="1" Grid.Column="0" Background="#121212" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0" Padding="24" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" CanContentScroll="True">
                    <StackPanel>
                        <TextBlock Text="BODY TYPES" Style="{StaticResource SidebarHeader}"/>
                        <Button x:Name="BtnNormal" Click="BodyTypeButton_Click" Tag="Normal" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Normal</Button>
                        <Button x:Name="BtnBouncy" Click="BodyTypeButton_Click" Tag="Bouncy" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Bouncy</Button>
                        <Button x:Name="BtnHeavy" Click="BodyTypeButton_Click" Tag="Heavy" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Heavy</Button>
                        <Button x:Name="BtnExplosive" Click="BodyTypeButton_Click" Tag="Explosive" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Explosive</Button>
                        <Button x:Name="BtnRepulsor" Click="BodyTypeButton_Click" Tag="Repulsor" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Repulsor</Button>
                        <Button x:Name="BtnGravityWell" Click="BodyTypeButton_Click" Tag="GravityWell" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Gravity Well</Button>
                        <Button x:Name="BtnTurbo" Click="BodyTypeButton_Click" Tag="Turbo" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Turbo</Button>
                        <Button x:Name="BtnPhantom" Click="BodyTypeButton_Click" Tag="Phantom" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Phantom</Button>
                        <Button x:Name="BtnSpike" Click="BodyTypeButton_Click" Tag="Spike" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Spike</Button>
                        <Button x:Name="BtnGlue" Click="BodyTypeButton_Click" Tag="Glue" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Glue</Button>
                        <Button x:Name="BtnPlasma" Click="BodyTypeButton_Click" Tag="Plasma" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Plasma</Button>
                        <Button x:Name="BtnBlackHole" Click="BodyTypeButton_Click" Tag="BlackHole" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Black Hole</Button>
                        <Button x:Name="BtnLightning" Click="BodyTypeButton_Click" Tag="Lightning" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Lightning</Button>
                        <Button x:Name="BtnFire" Click="BodyTypeButton_Click" Tag="Fire" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Fire</Button>
                        <Button x:Name="BtnAngel" Click="BodyTypeButton_Click" Tag="Angel" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Angel</Button>
                        <Button x:Name="BtnMolly" Click="BodyTypeButton_Click" Tag="Molly" Style="{StaticResource SidebarButton}" Margin="0,0,0,5">Molly</Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Game canvas -->
            <local:PhysicsCanvas x:Name="GameCanvas" Grid.Row="1" Grid.Column="1" ClipToBounds="True" Background="#0D0D0D"/>
            
            <!-- Bottom help -->
            <Border Grid.Row="3" Grid.ColumnSpan="2" Background="Transparent" Padding="24,12" HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource HelpText}" Text="LMB: SPAWN | RMB: EXPLODE | SPACE: PAUSE | C: CLEAR | G: GRAVITY | W: WIND | +/- : SPEED"/>
            </Border>
        </Grid>
    </Grid>
</Window>