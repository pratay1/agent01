<Window x:Class="PhysicsSandbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Physics Sandbox" Height="800" Width="1300"
        Background="#121212" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#121212" BorderBrush="#1f1f1f" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <TextBlock Text="Physics Sandbox" Foreground="#ffffff" FontSize="14" 
                           VerticalAlignment="Center" FontWeight="Medium"/>
                
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" Text="0 bodies" Foreground="#888888" 
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <Button x:Name="ClearButton" Content="CLEAR" Click="ClearButton_Click"
                            Width="60" Height="28" Background="#1f1f1f" 
                            Foreground="#ffffff" BorderThickness="0"
                            FontSize="11" FontWeight="Medium" Cursor="Hand"
                            Margin="0,0,8,0"/>
                    
                    <Button x:Name="PauseButton" Content="PAUSE" Click="PauseButton_Click"
                            Width="60" Height="28" Background="#1f1f1f" 
                            Foreground="#ffffff" BorderThickness="0"
                            FontSize="11" FontWeight="Medium" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- Game Canvas -->
        <Canvas x:Name="GameCanvas" Grid.Row="1" ClipToBounds="True"
                Background="#121212"/>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="#121212" BorderBrush="#1f1f1f" BorderThickness="0,1,0,0">
            <TextBlock Foreground="#555555" FontSize="11" 
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                LMB - Spawn/Drag  |  RMB - Explode  |  SPACE - Pause  |  C - Clear  |  G - Gravity  |  W - Wind
            </TextBlock>
        </Border>
    </Grid>
</Window>