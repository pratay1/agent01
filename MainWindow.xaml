<Window x:Class="PhysicsSandbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="2D Physics Sandbox" Height="720" Width="1400"
        Background="#1E1E23" WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        MouseMove="Window_MouseMove"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#252530" Padding="10,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ToolbarToggleButton" 
                        Content="☰" 
                        Width="30" Height="30"
                        Background="Transparent"
                        Foreground="#AAAAAA"
                        BorderThickness="0"
                        Click="ToolbarToggleButton_Click"
                        ToolTip="Toggle Body Selection Toolbar"/>
                <TextBlock x:Name="TitleText" Text="2D Physics Sandbox" 
                          Foreground="#AAAAAA" FontSize="14" FontWeight="Bold"
                          Margin="0,0,10,0"/>
            </StackPanel>
        </Border>
        
        <!-- Game Canvas -->
        <Canvas x:Name="GameCanvas" Grid.Row="1" Grid.Column="0" ClipToBounds="True"/>
        
        <!-- Body Selection Toolbar -->
        <Border x:Name="BodyToolbar" 
                Grid.Row="1" Grid.Column="1" 
                Background="#252530" 
                Width="250"
                HorizontalAlignment="Right">
            <StackPanel Margin="10">
                <TextBlock Text="Select Body Type:" 
                          Foreground="#AAAAAA" FontSize="12" FontWeight="Bold"
                          Margin="0,0,0,10"/>
                
                <!-- Normal Body -->
                <Border x:Name="NormalBodyButton"
                        Background="#3A3A45"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        MouseEnter="BodyButton_MouseEnter"
                        MouseLeave="BodyButton_MouseLeave"
                        MouseLeftButtonDown="NormalBodyButton_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="16" Height="16" Fill="#4FC3F7" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Normal" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock x:Name="NormalBodyDesc" 
                                      Text="Standard physics body" 
                                      Foreground="#888888" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Bouncy Body -->
                <Border x:Name="BouncyBodyButton"
                        Background="#3A3A45"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        MouseEnter="BodyButton_MouseEnter"
                        MouseLeave="BodyButton_MouseLeave"
                        MouseLeftButtonDown="BouncyBodyButton_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="16" Height="16" Fill="#81C784" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Bouncy" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock x:Name="BouncyBodyDesc" 
                                      Text="High restitution, bounces more" 
                                      Foreground="#888888" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Heavy Body -->
                <Border x:Name="HeavyBodyButton"
                        Background="#3A3A45"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        MouseEnter="BodyButton_MouseEnter"
                        MouseLeave="BodyButton_MouseLeave"
                        MouseLeftButtonDown="HeavyBodyButton_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="16" Height="16" Fill="#FFB74D" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Heavy" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock x:Name="HeavyBodyDesc" 
                                      Text="High mass, harder to move" 
                                      Foreground="#888888" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Explosive Body -->
                <Border x:Name="ExplosiveBodyButton"
                        Background="#3A3A45"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        MouseEnter="BodyButton_MouseEnter"
                        MouseLeave="BodyButton_MouseLeave"
                        MouseLeftButtonDown="ExplosiveBodyButton_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="16" Height="16" Fill="#E57373" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Explosive" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock x:Name="ExplosiveBodyDesc" 
                                      Text="Explodes on contact with other bodies" 
                                      Foreground="#888888" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Repulsor Body -->
                <Border x:Name="RepulsorBodyButton"
                        Background="#3A3A45"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,0,0,8"
                        MouseEnter="BodyButton_MouseEnter"
                        MouseLeave="BodyButton_MouseLeave"
                        MouseLeftButtonDown="RepulsorBodyButton_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="16" Height="16" Fill="#BA68C8" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Repulsor" Foreground="#FFFFFF" FontSize="11"/>
                            <TextBlock x:Name="RepulsorBodyDesc" 
                                      Text="Repels nearby bodies" 
                                      Foreground="#888888" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#252530" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Bodies: 0 | FPS: 60 | Press Space to Pause" 
                            Foreground="#888888" FontSize="11" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
        
        <!-- Controls Help -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#1A1A1F" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#555560" FontSize="10" FontFamily="Consolas">
                    <Run Text="[SPACE] Pause"/><Run Text="  |  "/><Run Text="[C] Clear"/><Run Text="  |  "/><Run Text="[G] Gravity"/><Run Text="  |  "/><Run Text="[W] Wind"/><Run Text="  |  "/><Run Text="[+/-] Speed"/><Run Text="  |  "/><Run Text="[LMB] Spawn/Fling"/><Run Text="  |  "/><Run Text="[RMB] Explode"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>